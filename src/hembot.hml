// Hembot — an interactive Hemlock coding agent.
// Talks to a local llama-server (OpenAI-compatible /v1/chat/completions),
// extracts Hemlock code from responses, runs it in a sandbox,
// and optionally feeds errors back for self-correction.

import { post_json_timeout, post_json_stream } from "@stdlib/http";
import { parse as json_parse, stringify as json_stringify } from "@stdlib/json";
import { read_file, write_file, exists } from "@stdlib/fs";
import { run_capture_safe } from "@stdlib/shell";
import { BOLD, DIM, CYAN, GREEN, RED, RESET } from "@stdlib/terminal";

import { extract_code, build_retry_feedback, parse_sse_events, parse_openai_delta } from "./extract.hml";
import { load_config, parse_cli } from "./config.hml";

// ────────────────────────────────────────────────────────────────────────────
// LLM call — streaming version. Prints each token as it arrives and returns
// the full concatenated response at the end. Falls back to non-streaming
// silently via `chat_blocking` when `config.stream` is false (handy for
// tests and for servers that don't support SSE).

fn chat_blocking(config, messages) {
    let payload = {
        model: config.model,
        messages: messages,
        temperature: config.temperature,
        max_tokens: config.max_tokens,
    };

    let resp = post_json_timeout(config.url, payload, config.timeout_ms);
    if (resp.status_code != 200) {
        throw `LLM request failed: HTTP ${resp.status_code}\n${resp.body}`;
    }

    let data = json_parse(resp.body);
    return data.choices[0].message.content;
}

fn chat_streaming(config, messages, label) {
    let payload = {
        model: config.model,
        messages: messages,
        temperature: config.temperature,
        max_tokens: config.max_tokens,
        stream: true,
    };

    let s = post_json_stream(config.url, payload, config.timeout_ms);
    if (s.status_code != 200) {
        s.close();
        throw `LLM request failed: HTTP ${s.status_code}`;
    }

    // Print the label exactly once, at the start.
    write(label);

    let full = "";
    let buffer = "";
    let finished = false;

    while (!s.done && !finished) {
        let chunk = s.read(config.timeout_ms);
        if (chunk == null) { break; }
        buffer = buffer + chunk;

        let parsed = parse_sse_events(buffer);
        buffer = parsed.remainder;

        for (payload_str in parsed.events) {
            let delta = parse_openai_delta(payload_str, json_parse);
            if (delta.length > 0) {
                write(delta);
                full = full + delta;
            }
        }

        if (parsed.done) { finished = true; }
    }

    s.close();
    write("\n");  // terminate the streamed line so the next prompt is on its own row
    return full;
}

fn chat(config, messages, label) {
    if (config.stream) {
        return chat_streaming(config, messages, label);
    }
    let response = chat_blocking(config, messages);
    write(label + response + "\n");
    return response;
}

// ────────────────────────────────────────────────────────────────────────────
// Sandbox execution

fn run_hemlock(code) {
    let tmpfile = "/tmp/hembot_snippet.hml";
    write_file(tmpfile, code);
    // argv-style: no shell metacharacters, no warnings, no injection.
    // `timeout` is just another executable that wraps its child, so it
    // works fine inside argv form.
    let result = run_capture_safe(["timeout", "10", "hemlock", tmpfile]);
    let stdout = result.stdout ?? "";
    let stderr = result.stderr ?? "";
    // Merge streams so the user sees syntax/runtime errors too.
    let output = stdout;
    if (stderr.length > 0) {
        if (output.length > 0 && !output.ends_with("\n")) {
            output = output + "\n";
        }
        output = output + stderr;
    }
    return {
        exit_code: result.code,
        output: output,
    };
}

// ────────────────────────────────────────────────────────────────────────────
// UI helpers

fn banner() {
    print(`${BOLD}${CYAN}╔══════════════════════════════════════╗${RESET}`);
    print(`${BOLD}${CYAN}║  Hembot — Hemlock Coding Agent       ║${RESET}`);
    print(`${BOLD}${CYAN}╚══════════════════════════════════════╝${RESET}`);
    print(`${DIM}Type a question. Ctrl-D or 'exit' to quit.${RESET}`);
    print(`${DIM}Slash commands: /reset, /save <file>, /load <file>, /help${RESET}`);
    print("");
}

fn assistant_label(): string {
    return `${GREEN}Hembot:${RESET} `;
}

fn print_error(text) {
    eprint(`${RED}Error:${RESET} ${text}`);
}

fn print_sandbox(result) {
    let tag = result.exit_code == 0
        ? `${GREEN}✓ ran cleanly${RESET}`
        : `${RED}✗ exit ${result.exit_code}${RESET}`;
    print(`${DIM}── sandbox: ${tag}${RESET}`);
    print(result.output);
    print(`${DIM}──${RESET}`);
}

// ────────────────────────────────────────────────────────────────────────────
// Slash commands

fn handle_slash(cmd, messages) {
    let parts = cmd.trim().split(" ");
    let op = parts[0];

    if (op == "/reset") {
        let first = messages[0];  // keep system prompt
        messages.clear();
        messages.push(first);
        print(`${DIM}Conversation reset.${RESET}`);
        return messages;
    }

    if (op == "/save" && parts.length >= 2) {
        write_file(parts[1], json_stringify(messages));
        print(`${DIM}Saved ${messages.length} messages to ${parts[1]}.${RESET}`);
        return messages;
    }

    if (op == "/load" && parts.length >= 2) {
        if (!exists(parts[1])) {
            print_error(`No such file: ${parts[1]}`);
            return messages;
        }
        let loaded = json_parse(read_file(parts[1]));
        print(`${DIM}Loaded ${loaded.length} messages from ${parts[1]}.${RESET}`);
        return loaded;
    }

    if (op == "/help") {
        print(`  /reset         — clear conversation (keeps system prompt)`);
        print(`  /save <file>   — save conversation as JSON`);
        print(`  /load <file>   — load conversation from JSON`);
        print(`  /help          — this message`);
        return messages;
    }

    print_error(`Unknown command: ${op}`);
    return messages;
}

// ────────────────────────────────────────────────────────────────────────────
// Auto-retry with error feedback

fn retry_loop(config, messages, last_result) {
    let attempt = 0;
    while (attempt < config.max_retries && last_result.exit_code != 0) {
        attempt = attempt + 1;
        let feedback = build_retry_feedback(last_result);
        messages.push({ role: "user", content: feedback });

        print(`${DIM}── retry ${attempt}/${config.max_retries} ──${RESET}`);
        let response = null;
        try {
            response = chat(config, messages, assistant_label());
        } catch (e) {
            print_error(`${e}`);
            messages.pop();
            return;
        }

        messages.push({ role: "assistant", content: response });

        let code = extract_code(response);
        if (code == null) {
            print(`${DIM}No code in retry response; giving up.${RESET}`);
            return;
        }
        last_result = run_hemlock(code);
        print_sandbox(last_result);
    }
}

// ────────────────────────────────────────────────────────────────────────────
// Main loop

fn main() {
    let parsed = parse_cli(args);
    let config = load_config(parsed);

    if (!exists(config.system_prompt_file)) {
        print_error(`System prompt file not found: ${config.system_prompt_file}`);
        return;
    }

    let system_prompt = read_file(config.system_prompt_file);
    let messages = [{ role: "system", content: system_prompt }];

    banner();

    loop {
        write(`${BOLD}you>${RESET} `);
        let input = read_line();
        if (input == null) {
            print("");
            break;
        }

        let trimmed = input.trim();
        if (trimmed == "") { continue; }
        if (trimmed == "exit" || trimmed == "quit") { break; }
        if (trimmed.starts_with("/")) {
            messages = handle_slash(trimmed, messages);
            continue;
        }

        messages.push({ role: "user", content: input });

        let response = null;
        try {
            response = chat(config, messages, assistant_label());
        } catch (e) {
            print_error(`${e}`);
            messages.pop();
            continue;
        }

        messages.push({ role: "assistant", content: response });

        if (config.run_code) {
            let code = extract_code(response);
            if (code != null) {
                let result = run_hemlock(code);
                print_sandbox(result);

                if (config.auto_retry && result.exit_code != 0) {
                    retry_loop(config, messages, result);
                }
            }
        }
    }

    print(`${DIM}Goodbye.${RESET}`);
}

main();
