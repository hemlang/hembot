// Pure helpers for extracting and repairing code from an LLM response.
// Kept as a separate module so they can be unit-tested without spinning up
// a chat server.

// Pull the first ```hemlock / ```hml / ``` fenced block from `response`.
// Returns the trimmed code, or null if no fenced block is found.
export fn extract_code(response) {
    let fence_tags = ["```hemlock", "```hml", "```"];
    for (tag in fence_tags) {
        let start = response.find(tag);
        if (start >= 0) {
            let after = start + tag.length;
            // Skip an optional newline immediately after the opening fence
            if (after < response.length && response.char_at(after) == '\n') {
                after = after + 1;
            }
            let rest = response.slice(after);
            let end = rest.find("```");
            if (end >= 0) {
                return rest.slice(0, end).trim();
            }
        }
    }
    return null;
}

// Build a short feedback message the agent can send back to the model
// after running extracted code. `result` should have `exit_code` and `output`.
export fn build_retry_feedback(result) {
    let output = result.output ?? "";
    return `That code failed when I ran it. Exit code ${result.exit_code}.\n\nOutput:\n${output}\n\nPlease fix and try again.`;
}

// Parse one pass of an OpenAI-style SSE chunk-buffer into its finished events,
// returning { events: [delta_strings...], done: bool, remainder: string }.
//
// The caller feeds raw bytes from `post_json_stream.read()` into an accumulator
// and calls this to drain whatever complete events are now present. Anything
// incomplete (e.g. a partial "data: " line with no blank-line terminator yet)
// stays in `remainder` for the next pass.
//
// Each SSE event looks like:
//
//   data: {"choices":[{"delta":{"content":"Hello"}}]}
//   \n
//
// Terminator is the literal line `data: [DONE]`.
export fn parse_sse_events(buffer: string): object {
    let events = [];
    let done = false;
    let cursor = 0;
    let len = buffer.length;

    while (cursor < len) {
        // An event ends at a blank line (\n\n or \r\n\r\n).
        let rest = buffer.slice(cursor);
        let nn = rest.find("\n\n");
        let rnrn = rest.find("\r\n\r\n");
        let end = -1;
        let skip = 0;
        if (rnrn >= 0 && (nn < 0 || rnrn < nn)) {
            end = rnrn;
            skip = 4;
        } else if (nn >= 0) {
            end = nn;
            skip = 2;
        }
        if (end < 0) { break; }  // incomplete event, wait for more bytes

        let event_str = rest.slice(0, end);
        cursor = cursor + end + skip;

        // An event may contain multiple `data:` lines that are concatenated.
        let data_parts = [];
        let lines = event_str.split("\n");
        for (line in lines) {
            if (line.length > 0 && line.ends_with("\r")) {
                line = line.slice(0, line.length - 1);
            }
            if (line.starts_with("data: ")) {
                data_parts.push(line.slice(6));
            } else if (line.starts_with("data:")) {
                data_parts.push(line.slice(5));
            }
        }
        if (data_parts.length == 0) { continue; }

        let data = data_parts.join("\n");
        if (data == "[DONE]") {
            done = true;
            break;
        }
        events.push(data);
    }

    return {
        events: events,
        done: done,
        remainder: buffer.slice(cursor),
    };
}

// Extract the token text delta from one OpenAI-format JSON payload.
// Payload example:
//   {"choices":[{"delta":{"content":"Hello"}}]}
// Returns the content string, or "" if the payload doesn't carry a delta.
// `json_parse` is injected so this module stays free of stdlib coupling.
export fn parse_openai_delta(payload_str: string, json_parse): string {
    try {
        let obj = json_parse(payload_str);
        let choices = obj.choices;
        if (choices == null || choices.length == 0) { return ""; }
        let delta = choices[0].delta;
        if (delta == null) { return ""; }
        let content = delta.content;
        if (content == null) { return ""; }
        return content;
    } catch (e) {
        return "";
    }
}
